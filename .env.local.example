# Local development — copy to .env.local and fill in values (never commit .env.local)
APP_ENV=local
LOCAL_DEV_AUTH_BYPASS=true

APP_SECRET=
POSTGRES_PASSWORD=
POSTGRES_MIGRATE_PASSWORD=
POSTGRES_RUNTIME_PASSWORD=
E2E_POSTGRES_PASSWORD=
E2E_MIGRATE_PASSWORD=
E2E_RUNTIME_PASSWORD=
TOKEN_ENCRYPTION_KEY=
AAROHAN_OWNER_DB_IDENTITY_UUID=
AAROHAN_E2E_DB_IDENTITY_UUID=
AAROHAN_DESTRUCTIVE_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=

GOOGLE_OAUTH_SECRETS_DIR=C:/AarohanSecrets
GOOGLE_OAUTH_CLIENT_JSON_PATH=C:\AarohanSecrets\google-oauth-client.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback
CAREER_GMAIL_ADDRESS=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_PROJECT_NUMBER=
OAUTH_FIXTURE_MODE=false
ENABLE_EXTERNAL_EMAIL_SEND=false

# Job connector credentials (optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
USAJOBS_API_KEY=
USAJOBS_USER_EMAIL=
RSS_FEED_URLS=
CONNECTOR_FIXTURE_MODE=false
TEST_EMAIL_ALLOWLIST=
AI_API_KEY=
N8N_ENCRYPTION_KEY=
